# ===========================================
# BACKEND-APP - Environment Variables
# ===========================================
# Copy file này thành .env và điền các giá trị thực tế
# cp .env.example .env (Linux/Mac)
# copy .env.example .env (Windows)
# ===========================================

# ---- Server Configuration ----
PORT=5000

# ---- MongoDB ----
# Đổi URI phù hợp với môi trường của bạn
MONGO_URI=mongodb://localhost:27017/vks_app_desktop

# ---- OpenAI API Key ----
# Lấy key tại: https://platform.openai.com/api-keys
# Dùng cho tính năng AI extract thông tin vụ án
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_API_KEY_HERE
